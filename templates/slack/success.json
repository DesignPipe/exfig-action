{
  "attachments": [{
    "color": "{{COLOR}}",
    "blocks": [
      {
        "type": "header",
        "text": {
          "type": "plain_text",
          "text": "{{ICON}} ExFig: {{TITLE}}",
          "emoji": true
        }
      },
      {
        "type": "section",
        "fields": [
          {"type": "mrkdwn", "text": "*Command:*\n`{{COMMAND}}`"},
          {"type": "mrkdwn", "text": "*Assets:*\n{{ASSETS}}"}
        ]
      },
      {
        "type": "section",
        "fields": [
          {"type": "mrkdwn", "text": "*Repository:*\n{{REPO}}"},
          {"type": "mrkdwn", "text": "*Duration:*\n{{DURATION}}"}
        ]
      },
      {
        "type": "actions",
        "elements": [
          {
            "type": "button",
            "text": {"type": "plain_text", "text": "View Run", "emoji": true},
            "url": "{{RUN_URL}}"
          }
        ]
      }
    ]
  }]
}
